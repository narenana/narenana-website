# Copy to .dev.vars for local Pages Function development. .dev.vars is
# gitignored. Values here OVERRIDE [vars] in wrangler.toml for local runs.
# In production these are set on the Cloudflare dashboard or kept in
# wrangler.toml [vars] (non-secret values).

# Where /log-viewer/* gets forwarded. Local dev: point at the tool's Vite
# dev server. Production: the Pages deployment URL of edgetx-log-parser.
LOG_VIEWER_ORIGIN=http://localhost:5173
