{
  "name": "customer-website",
  "version": "0.1.0",
  "private": true,
  "description": "Customer-facing site + path-prefix router for tool deployments",
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:site": "npx serve site -l 3000",
    "deploy:worker": "wrangler deploy",
    "deploy:site": "wrangler pages deploy site --project-name=customer-site"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
