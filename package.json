{
  "name": "narenana-website",
  "version": "0.3.0",
  "private": true,
  "description": "narenana.com \u2014 Cloudflare Worker with static assets, routing, and YouTube feed cache",
  "scripts": {
    "dev": "wrangler dev",
    "dev:static": "npx serve site -l 3000",
    "assets": "node scripts/gen-assets.mjs",
    "wings:css": "node wings/lib/gen-styles.mjs",
    "deploy": "wrangler deploy",
    "wings:test": "node --test wings/test/suite.mjs"
  },
  "devDependencies": {
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "wrangler": "^4.111.0"
  }
}
